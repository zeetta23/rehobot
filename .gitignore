# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.nyc_output/

# next.js
/.next/
/out/

# production
/build
dist/

# misc
.DS_Store
.AppleDouble
.LSOverride
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDEs / editores
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Firebase (archivos sensibles o generados)
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
*-firebase-adminsdk-*.json
serviceAccountKey.json
